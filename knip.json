{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignore": [
    "**/__tests__/helpers.ts",
    "extensions/pi-autoresearch/src/command.ts",
    "extensions/pi-autoresearch/src/lifecycle/handlers.ts",
    "extensions/pi-autoresearch/src/lifecycle/index.ts",
    "extensions/pi-autoresearch/src/tools/index.ts",
    "harness/server.ts"
  ],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": ["extensions/*/index.ts"],
      "project": ["extensions/**/*.ts", "harness/**/*.ts"]
    }
  }
}
